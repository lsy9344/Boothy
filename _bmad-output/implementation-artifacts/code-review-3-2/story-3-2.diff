+fn update_timing(
+    base_dir: &PathBuf,
+    session_id: &str,
+    warning_at: &str,
+    adjusted_end_at: &str,
+    phase: &str,
+) {
+    let manifest_path = SessionPaths::new(base_dir, session_id).manifest_path;
+    let manifest_bytes = fs::read_to_string(&manifest_path).expect("manifest should be readable");
