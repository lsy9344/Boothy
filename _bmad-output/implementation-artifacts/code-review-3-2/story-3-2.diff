+        .as_mut()
+        .expect("session timing should exist");
+    timing.warning_at = warning_at.into();
+    timing.adjusted_end_at = adjusted_end_at.into();
+    timing.phase = phase.into();
+    timing.capture_allowed = phase != "ended";
