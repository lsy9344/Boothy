+    generatedAt = $generatedAt
+    sessionId = $SessionId
+    presetId = $PresetId
+    publishedVersion = $PublishedVersion
+    captureId = $CaptureId
+    traceRoot = $TraceRoot
+    traces = [ordered]@{
