+
+fn clear_active_session(base_dir: &Path, branch_id: &str) {
+    let store_path = base_dir.join("branch-config").join("state.json");
+    let bytes = fs::read_to_string(&store_path).expect("store should exist");
+    let mut store: serde_json::Value =
+        serde_json::from_str(&bytes).expect("store should deserialize");
+
+    let branches = store["branches"]
+        .as_array_mut()
+        .expect("branches should be an array");
+
+    for branch in branches {
+        if branch["branchId"].as_str() == Some(branch_id) {
+            branch["activeSession"] = serde_json::Value::Null;
+        }
+    }
+
+    fs::write(
+        store_path,
+        serde_json::to_vec_pretty(&store).expect("store should serialize"),
+    )
+    .expect("store should write");
+}
