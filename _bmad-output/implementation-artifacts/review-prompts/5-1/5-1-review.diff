+fn load_current_session_manifest(
+    base_dir: &Path,
+) -> Result<Option<(PathBuf, SessionManifest)>, HostErrorEnvelope> {
+    let sessions_root = base_dir.join("sessions");
+
+    if !sessions_root.exists() {
+        return Ok(None);
+    }
+
+    let session_dirs = fs::read_dir(&sessions_root).map_err(|error| {
+        HostErrorEnvelope::persistence(format!("нҳ„мһ¬ м„ём…ҳ лӘ©лЎқмқ„ мқҪм§Җ лӘ»н–Ҳм–ҙмҡ”: {error}"))
+    })?;
+    let mut latest: Option<(String, String, PathBuf, SessionManifest)> = None;
+    let mut first_error: Option<HostErrorEnvelope> = None;
+
+    for entry in session_dirs {
+        let session_root = match entry {
+            Ok(entry) => entry.path(),
+            Err(_) => continue,
+        };
+
+        if !session_root.is_dir() {
+            continue;
+        }
+
+        let Some(session_name) = session_root
+            .file_name()
+            .and_then(|value| value.to_str())
+            .map(str::to_string)
+        else {
+            continue;
+        };
+
+        if session_name.starts_with(".creating-") {
+            continue;
+        }
+
+        let manifest_path = session_root.join("session.json");
+        if !manifest_path.is_file() {
+            continue;
+        }
+
+        match read_session_manifest(&manifest_path) {
+            Ok(manifest) => {
+                let candidate_key = manifest.updated_at.clone();
+                let should_replace = latest
+                    .as_ref()
+                    .map(|(current_key, current_session_id, _, _)| {
+                        candidate_key > *current_key
+                            || (candidate_key == *current_key
+                                && manifest.session_id > *current_session_id)
+                    })
+                    .unwrap_or(true);
+
+                if should_replace {
+                    latest = Some((
+                        candidate_key,
+                        manifest.session_id.clone(),
+                        manifest_path,
+                        manifest,
+                    ));
+                }
+            }
+            Err(error) => {
+                if first_error.is_none() {
+                    first_error = Some(error);
+                }
+            }
+        }
+    }
+
+    if let Some((_, _, manifest_path, manifest)) = latest {
+        return Ok(Some((manifest_path, manifest)));
+    }
+
+    if let Some(error) = first_error {
+        return Err(error);
+    }
+
+    Ok(None)
+}
+
+fn read_diagnostics_context(base_dir: &Path, session_id: &str) -> DiagnosticsContext {
+    let log_path = match SessionPaths::try_new(base_dir, session_id) {
+        Ok(paths) => paths.diagnostics_dir.join("timing-events.log"),
+        Err(_) => return DiagnosticsContext::default(),
+    };
+
+    if !log_path.is_file() {
+        return DiagnosticsContext::default();
+    }
+
+    let Ok(contents) = fs::read_to_string(log_path) else {
+        return DiagnosticsContext {
+            malformed: true,
+            ..DiagnosticsContext::default()
+        };
+    };
+    let Some(last_line) = contents.lines().rev().find(|line| !line.trim().is_empty()) else {
+        return DiagnosticsContext::default();
+    };
+    let parts: Vec<_> = last_line.split('\t').collect();
+    if parts.is_empty() {
+        return DiagnosticsContext {
+            malformed: true,
+            ..DiagnosticsContext::default()
+        };
+    }
+    if rfc3339_to_unix_seconds(parts[0]).is_err() {
+        return DiagnosticsContext {
+            malformed: true,
+            ..DiagnosticsContext::default()
+        };
+    }
+
+    let mut context = DiagnosticsContext {
+        observed_at: Some(parts[0].to_string()),
+        ..DiagnosticsContext::default()
+    };
+
+    for part in parts.into_iter().skip(1) {
+        let Some((key, value)) = part.split_once('=') else {
+            context.malformed = true;
+            return context;
+        };
+
+        match key {
+            "event" => context.event_name = Some(value.to_string()),
+            "state" => context.post_end_state = Some(value.to_string()),
+            _ => {}
+        }
+    }
+
+    context
+}
+
+fn build_capture_boundary(manifest: &SessionManifest, reason_code: &str) -> OperatorBoundarySummaryDto {
+    match reason_code {
+        "preset-missing" => blocked_boundary(
+            "мәЎмІҳ кІҪкі„ мӨҖл№„ м•Ҳ лҗЁ",
+            "нҷңм„ұ presetмқҙ м—Ҷм–ҙ м•„м§Ғ мҙ¬мҳҒмқ„ л°ӣмқ„ мҲҳ м—Ҷм–ҙмҡ”.",
+        ),
+        "camera-preparing" | "helper-preparing" => blocked_boundary(
+            "мәЎмІҳ мӨҖл№„ мӨ‘",
+            "мҙ¬мҳҒ кІҪкі„к°Җ м•„м§Ғ м—ҙлҰ¬м§Җ м•Ҡм•ҳм–ҙмҡ”. мӨҖл№„ мғҒнғңлҘј лӢӨмӢң нҷ•мқён•ҙ мЈјм„ёмҡ”.",
+        ),
+        _ if manifest.active_preset.is_some() => clear_boundary(
+            "мәЎмІҳ кІҪкі„ м •мғҒ",
+            "нҷңм„ұ presetмқҙ м„ нғқлҸј мһҲм–ҙ capture кІҪкі„лҠ” м—ҙл Ө мһҲм–ҙмҡ”.",
+        ),
+        _ => clear_boundary(
+            "мәЎмІҳ лҢҖкё° мӨ‘",
+            "м•„м§Ғ мөңк·ј м„ём…ҳ л¬ёл§Ҙл§Ң нҷ•мқё мӨ‘мқҙлқј capture кІҪкі„лҠ” л§үнһҲм§Җ м•Ҡм•ҳм–ҙмҡ”.",
+        ),
+    }
+}
+
+fn build_preview_render_boundary(render_status: Option<&str>) -> OperatorBoundarySummaryDto {
+    match render_status {
+        Some("captureSaved") | Some("previewWaiting") => blocked_boundary(
+            "н”„лҰ¬л·°/л ҢлҚ” кІ°кіј мӨҖл№„ м§Җм—°",
+            "к°ҖмһҘ мөңк·ј мҙ¬мҳҒліёмқҖ м ҖмһҘлҗҳм—Ҳм§Җл§Ң preview/render кІ°кіјк°Җ м•„м§Ғ мӨҖл№„лҗҳм§Җ м•Ҡм•ҳм–ҙмҡ”.",
+        ),
+        Some("renderFailed") => blocked_boundary(
+            "н”„лҰ¬л·°/л ҢлҚ” кІ°кіј мӨҖл№„ мӢӨнҢЁ",
+            "к°ҖмһҘ мөңк·ј мҙ¬мҳҒліёмқҳ кІ°кіјлҘј л§Ңл“Өм§Җ лӘ»н•ҙ м§Ғмӣҗ нҷ•мқёмқҙ н•„мҡ”н•ҙмҡ”.",
+        ),
+        Some("previewReady") | Some("finalReady") => clear_boundary(
+            "н”„лҰ¬л·°/л ҢлҚ” кІҪкі„ м •мғҒ",
+            "к°ҖмһҘ мөңк·ј мҙ¬мҳҒліёмқҳ кІ°кіј мӨҖл№„к°Җ лҒқлӮҳ мһҲм–ҙмҡ”.",
+        ),
+        _ => clear_boundary(
+            "мөңк·ј л ҢлҚ” м—ҶмқҢ",
+            "м•„м§Ғ нҷ•мқён•  мөңк·ј мҙ¬мҳҒ кё°лЎқмқҙ м—Ҷм–ҙ preview/render кІҪкі„лҠ” л№„м–ҙ мһҲм–ҙмҡ”.",
+        ),
+    }
+}
+
+fn build_completion_boundary(
+    post_end_state: Option<&str>,
+    timing_phase: Option<&str>,
+) -> OperatorBoundarySummaryDto {
+    match post_end_state {
+        Some(SESSION_POST_END_EXPORT_WAITING) => blocked_boundary(
+            "мҷ„лЈҢ нҢҗм • лҢҖкё°",
+            "мҙ¬мҳҒмқҖ лҒқлӮ¬кі  кІ°кіјмҷҖ лӢӨмқҢ м•ҲлӮҙлҘј м •лҰ¬н•ҳлҠ” мӨ‘мқҙм—җмҡ”.",
+        ),
+        Some(SESSION_POST_END_PHONE_REQUIRED) => blocked_boundary(
+            "мў…лЈҢ нӣ„ м§Ғмӣҗ нҷ•мқё н•„мҡ”",
+            "мў…лЈҢ нӣ„ мІҳлҰ¬ лӢЁкі„м—җм„ң мһҗлҸҷ мҷ„лЈҢлЎң л„ҳм–ҙк°Җм§Җ лӘ»н–Ҳм–ҙмҡ”.",
+        ),
+        Some(SESSION_POST_END_COMPLETED) => clear_boundary(
+            "мҷ„лЈҢ кІҪкі„ м •мғҒ",
+            "мў…лЈҢ нӣ„ м•ҲлӮҙк°Җ нҷ•м •лҸј мһҲм–ҙ completion кІҪкі„лҠ” м •лҰ¬лҗң мғҒнғңмҳҲмҡ”.",
+        ),
+        _ if timing_phase == Some("ended") => blocked_boundary(
+            "мў…лЈҢ нӣ„ мғҒнғң нҷ•мқё н•„мҡ”",
+            "м„ём…ҳ мӢңк°„мқҖ лҒқлӮ¬м§Җл§Ң мў…лЈҢ нӣ„ м•ҲлӮҙ мғҒнғңк°Җ м•„м§Ғ нҷ•м •лҗҳм§Җ м•Ҡм•ҳм–ҙмҡ”.",
+        ),
+        _ => clear_boundary(
+            "мҷ„лЈҢ кІҪкі„ лҢҖкё° м „",
+            "м•„м§Ғ мў…лЈҢ нӣ„ мҷ„лЈҢ кІҪкі„лЎң л“Өм–ҙк°Җм§Җ м•Ҡм•ҳм–ҙмҡ”.",
+        ),
+    }
+}
+
+fn derive_blocked_state_category(
+    capture_boundary: &OperatorBoundarySummaryDto,
+    preview_render_boundary: &OperatorBoundarySummaryDto,
+    completion_boundary: &OperatorBoundarySummaryDto,
+    post_end_state: Option<&str>,
+) -> &'static str {
+    if completion_boundary.status == "blocked"
+        || matches!(
+            post_end_state,
+            Some(SESSION_POST_END_EXPORT_WAITING) | Some(SESSION_POST_END_PHONE_REQUIRED)
+        )
+    {
+        return "timing-post-end-blocked";
+    }
+
+    if capture_boundary.status == "blocked" {
+        return "capture-blocked";
+    }
+
+    if preview_render_boundary.status == "blocked" {
+        return "preview-render-blocked";
+    }
+
+    "not-blocked"
+}
+
+fn build_recent_failure_summary(
+    capture_boundary: &OperatorBoundarySummaryDto,
+    preview_render_boundary: &OperatorBoundarySummaryDto,
+    completion_boundary: &OperatorBoundarySummaryDto,
+    diagnostics: &DiagnosticsContext,
+) -> Option<OperatorRecentFailureSummaryDto> {
+    if diagnostics.malformed {
+        return Some(OperatorRecentFailureSummaryDto {
+            title: "мөңк·ј м§„лӢЁ лЎңк·ёлҘј ліөмӣҗн•ҳм§Җ лӘ»н–Ҳм–ҙмҡ”.".into(),
+            detail:
+                "лЎңк·ё нҳ•мӢқмқҙ мҳ¬л°”лҘҙм§Җ м•Ҡм•„ нҳ„мһ¬ м„ём…ҳ мҡ”м•Ҫл§Ң кё°мӨҖмңјлЎң мҡҙмҳҒмһҗ м§„лӢЁмқ„ ліҙм—¬ мЈјкі  мһҲм–ҙмҡ”."
+                    .into(),
+            observed_at: None,
+        });
+    }
+
+    let blocked_boundary = if capture_boundary.status == "blocked" {
+        Some(capture_boundary)
+    } else if preview_render_boundary.status == "blocked" {
+        Some(preview_render_boundary)
+    } else if completion_boundary.status == "blocked" {
+        Some(completion_boundary)
+    } else {
+        None
+    }?;
+
+    Some(OperatorRecentFailureSummaryDto {
+        title: blocked_boundary.title.clone(),
+        detail: blocked_boundary.detail.clone(),
+        observed_at: diagnostics.observed_at.clone(),
+    })
+}
+
+fn clear_boundary(title: &str, detail: &str) -> OperatorBoundarySummaryDto {
+    OperatorBoundarySummaryDto {
+        status: "clear".into(),
+        title: title.into(),
+        detail: detail.into(),
+    }
+}
+
+fn blocked_boundary(title: &str, detail: &str) -> OperatorBoundarySummaryDto {
+    OperatorBoundarySummaryDto {
+        status: "blocked".into(),
+        title: title.into(),
+        detail: detail.into(),
+    }
+}
