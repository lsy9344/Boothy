+        .detail
+        .contains("лЎңк·ё нҳ•мӢқмқҙ мҳ¬л°”лҘҙм§Җ м•Ҡм•„"));
+    assert!(!recent_failure.detail.contains("C:\\render-worker\\stderr.log"));
+
+    let _ = fs::remove_dir_all(base_dir);
+}
