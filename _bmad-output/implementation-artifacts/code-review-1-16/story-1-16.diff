+            trigger = '${{ github.event_name }}'
+            ref = '${{ github.ref }}'
+            signingMode = $signingMode
+            signingSource = $signingSource
+            artifactRoot = $artifactRoot
+            hardwareLedger = '_bmad-output/implementation-artifacts/hardware-validation-ledger.md'
+          } | ConvertTo-Json -Depth 4
+
+          Set-Content -Path 'release-proof/release-proof.json' -Value $proof
+
+      - name: Upload release proof
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: windows-release-proof-${{ github.run_id }}
+          path: release-proof
+          if-no-files-found: error
+
+      - name: Upload Windows bundle outputs
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: windows-bundle-${{ github.run_id }}
+          path: |
+            src-tauri/target/debug/bundle
+            src-tauri/target/release/bundle
+          if-no-files-found: warn
