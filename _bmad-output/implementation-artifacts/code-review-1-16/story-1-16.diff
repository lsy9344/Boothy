+      - name: Run unsigned Windows baseline build
+        if: github.event_name == 'pull_request' || startsWith(github.ref, 'refs/heads/main')
         run: pnpm build:desktop
 
       - name: Run signing-ready draft build
         if: github.event_name == 'workflow_dispatch' || startsWith(github.ref, 'refs/tags/boothy-v')
         run: pnpm release:desktop
+
+      - name: Capture release proof summary
+        if: always()
+        shell: pwsh
+        run: |
+          New-Item -ItemType Directory -Force -Path release-proof | Out-Null
+
+          $artifactRoot = if (Test-Path 'src-tauri/target/release/bundle') {
+            'src-tauri/target/release/bundle/'
+          } elseif (Test-Path 'src-tauri/target/debug/bundle') {
+            'src-tauri/target/debug/bundle/'
+          } else {
+            'bundle-not-produced'
