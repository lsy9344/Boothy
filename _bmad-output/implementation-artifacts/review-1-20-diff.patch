+fn wait_for_shell_command_with_timeout(
+    command: tauri_plugin_shell::process::Command,
+    timeout: Duration,
+) -> Result<(), &'static str> {
+    let (mut receiver, child) = command.spawn().map_err(|_| "sidecar-launch-failed")?;
+    let (result_tx, result_rx) = mpsc::channel();
