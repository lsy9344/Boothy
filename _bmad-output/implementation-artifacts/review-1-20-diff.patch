+fn capture_preview_promotion_snapshots_in_dir(
+    base_dir: &Path,
+    session_id: &str,
+) -> Result<(PathBuf, PathBuf), HostErrorEnvelope> {
+    let paths = SessionPaths::try_new(base_dir, session_id)?;
+    let route_policy_source = base_dir
+        .join("branch-config")
+        .join("preview-renderer-policy.json");
+    let route_policy_snapshot_path = paths
+        .diagnostics_dir
+        .join("captured-preview-renderer-policy.json");
+    let catalog_state_source = base_dir.join("preset-catalog").join("catalog-state.json");
+    let catalog_state_snapshot_path = paths.diagnostics_dir.join("captured-catalog-state.json");
+
+    copy_snapshot_artifact(&route_policy_source, &route_policy_snapshot_path)?;
+    copy_snapshot_artifact(&catalog_state_source, &catalog_state_snapshot_path)?;
+
+    Ok((route_policy_snapshot_path, catalog_state_snapshot_path))
+}
+
+fn copy_snapshot_artifact(source: &Path, destination: &Path) -> Result<(), HostErrorEnvelope> {
+    let parent = destination.parent().ok_or_else(|| {
+        HostErrorEnvelope::persistence("snapshot artifact 경로를 준비하지 못했어요.")
+    })?;
+    fs::create_dir_all(parent).map_err(|error| {
+        HostErrorEnvelope::persistence(format!("snapshot artifact 경로를 만들지 못했어요: {error}"))
+    })?;
+    let bytes = fs::read(source).map_err(|error| {
+        HostErrorEnvelope::persistence(format!("snapshot source를 읽지 못했어요: {error}"))
+    })?;
+    fs::write(destination, bytes).map_err(|error| {
+        HostErrorEnvelope::persistence(format!("snapshot artifact를 저장하지 못했어요: {error}"))
+    })?;
+
+    Ok(())
+}
