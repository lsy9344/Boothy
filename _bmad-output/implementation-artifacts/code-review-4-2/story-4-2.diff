+
+    Ok(RollbackPresetCatalogResultDto::Rejected {
+        schema_version: PRESET_CATALOG_ROLLBACK_RESULT_SCHEMA_VERSION.into(),
+        reason_code: STAGE_UNAVAILABLE_REASON_CODE.into(),
+        message: rollback_stage_unavailable_message().into(),
+        guidance: rollback_stage_unavailable_guidance().into(),
+        catalog_revision: input.expected_catalog_revision,
+        summary: None,
+    })
