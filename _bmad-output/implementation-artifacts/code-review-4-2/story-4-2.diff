+
+fn load_stage_unavailable_publication_draft(
+    base_dir: &std::path::Path,
+    capability_snapshot: &CapabilitySnapshotDto,
+    preset_id: &str,
+) -> Result<DraftPresetSummaryDto, HostErrorEnvelope> {
+    let workspace = load_authoring_workspace_in_dir(base_dir, capability_snapshot)?;
+
+    workspace
+        .drafts
+        .into_iter()
+        .find(|draft| draft.preset_id == preset_id)
+        .ok_or_else(|| HostErrorEnvelope::validation_message("게시할 draft를 찾지 못했어요."))
+}
+
+fn build_stage_unavailable_publication_result(
+    base_dir: &std::path::Path,
+    capability_snapshot: &CapabilitySnapshotDto,
+    input: PublishValidatedPresetInputDto,
+) -> Result<PublishValidatedPresetResultDto, HostErrorEnvelope> {
+    validate_publish_validated_preset_input(&input)?;
+    let draft =
+        load_stage_unavailable_publication_draft(base_dir, capability_snapshot, &input.preset_id)?;
+    let draft_version = draft.draft_version;
+    let noted_at = current_timestamp(SystemTime::now())?;
+    let guidance = publication_stage_unavailable_guidance().to_string();
+
+    Ok(PublishValidatedPresetResultDto::Rejected {
+        schema_version: DRAFT_PRESET_PUBLICATION_RESULT_SCHEMA_VERSION.into(),
+        draft,
+        reason_code: STAGE_UNAVAILABLE_REASON_CODE.into(),
+        message: publication_stage_unavailable_message().into(),
+        guidance: guidance.clone(),
+        audit_record: PresetPublicationAuditRecordDto {
+            schema_version: PRESET_PUBLICATION_AUDIT_SCHEMA_VERSION.into(),
+            preset_id: input.preset_id,
+            draft_version,
+            published_version: input.published_version,
+            actor_id: input.actor_id,
+            actor_label: input.actor_label,
+            review_note: input.review_note,
+            action: "rejected".into(),
+            reason_code: Some(STAGE_UNAVAILABLE_REASON_CODE.into()),
+            guidance,
+            noted_at,
+        },
+    })
+}
+
+fn build_stage_unavailable_rollback_result(
+    input: RollbackPresetCatalogInputDto,
+) -> Result<RollbackPresetCatalogResultDto, HostErrorEnvelope> {
