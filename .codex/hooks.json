{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { $root = (git rev-parse --show-toplevel).Trim(); & (Join-Path $root '.codex/hooks/session-start-context.ps1') }\"",
            "statusMessage": "Loading camera capture workflow context",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { $root = (git rev-parse --show-toplevel).Trim(); & (Join-Path $root '.codex/hooks/user-prompt-context.ps1') }\"",
            "statusMessage": "Preparing camera capture troubleshooting context",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { $root = (git rev-parse --show-toplevel).Trim(); & (Join-Path $root '.codex/hooks/stop-enforce-and-log.ps1') }\"",
            "statusMessage": "Validating verification coverage and updating camera capture history",
            "timeout": 90
          }
        ]
      }
    ]
  }
}
