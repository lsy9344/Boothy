{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "operator-window",
  "description": "Reserved permissions for a future operator window surface.",
  "windows": ["operator-window"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "../sidecar/dedicated-renderer/boothy-dedicated-renderer",
          "sidecar": true,
          "args": [
            "--protocol",
            {
              "validator": "^(preview-job-v1|warmup-v1)$"
            },
            "--request",
            {
              "validator": "^.+\\.json$"
            },
            "--result",
            {
              "validator": "^.+\\.json$"
            }
          ]
        }
      ]
    }
  ]
}
